# ── App
NODE_ENV=development
PORT=3000

# ── Database
DATABASE_URL="postgresql://velopx:velopx_secret@localhost:5432/velopx"

# ── Redis
REDIS_URL="redis://:redis_secret@localhost:6379"

# ── Kafka
KAFKA_BROKERS=localhost:9092

# ── Clerk (Backend)
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3001,http://localhost:3101

# ── Docker host ports (optional — defaults 3100/3101)
# VELOPX_API_PORT=3100
# VELOPX_WEB_PORT=3101

# ── Next.js / Web
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_API_URL=http://localhost:3000

# ── Expo / Mobile (per-app .env)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_API_URL=http://localhost:3000
