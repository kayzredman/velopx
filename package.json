{
  "name": "velopx",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "concurrently -n backend,web -c cyan,magenta \"pnpm run dev:backend\" \"pnpm run dev:web\"",
    "dev:backend": "pnpm --filter backend dev",
    "dev:web": "pnpm --filter web dev",
    "dev": "concurrently \"pnpm run dev:backend\" \"pnpm run dev:web\"",
    "docker:infra": "docker compose up -d postgres redis zookeeper kafka kafka-ui",
    "docker:db": "docker compose up -d postgres",
    "docker:up": "docker compose --profile app up -d --build",
    "demo:up": "bash scripts/demo-up.sh",
    "docker:down": "docker compose --profile app down",
    "docker:logs": "docker compose --profile app logs -f",
    "docker:reset": "docker compose --profile app down -v",
    "setup": "cp -n .env.example .env 2>/dev/null || true && pnpm install && pnpm db:generate && pnpm --filter backend db:push",
    "seed": "bash scripts/seed-demo.sh",
    "seed:clerk": "pnpm --filter backend seed:clerk",
    "seed:team": "pnpm --filter backend seed:clerk && pnpm --filter backend seed:team",
    "seed:verify": "bash scripts/seed-verify.sh",
    "local:db": "bash scripts/setup-local-postgres.sh",
    "smoke:api": "bash scripts/smoke-api.sh",
    "smoke:web": "bash scripts/smoke-web.sh",
    "smoke:mobile": "bash scripts/smoke-mobile.sh",
    "smoke:all": "API_URL=${API_URL:-http://localhost:3100} WEB_URL=${WEB_URL:-http://localhost:3101} bash scripts/smoke-web.sh && API_URL=${API_URL:-http://localhost:3100} bash scripts/smoke-mobile.sh",
    "dev:mobile:dealer": "pnpm --filter dealer --dir mobile/apps/dealer start",
    "dev:mobile:garage": "pnpm --filter garage --dir mobile/apps/garage start",
    "dev:mobile:driver": "pnpm --filter driver --dir mobile/apps/driver start",
    "db:generate": "pnpm --filter backend db:generate",
    "db:migrate": "pnpm --filter backend db:migrate",
    "db:seed": "pnpm --filter backend db:seed",
    "db:sync": "bash scripts/db-sync.sh",
    "db:link-me": "pnpm --filter backend db:link-me",
    "db:reset-seed": "pnpm --filter backend db:reset-seed",
    "build": "pnpm --filter backend build && pnpm --filter web build"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "pnpm": {
    "overrides": {
      "expo-crypto": "~15.0.9",
      "react-native": "0.81.5",
      "sucrase": "3.34.0"
    }
  }
}
