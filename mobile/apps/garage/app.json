{
  "expo": {
    "name": "velopX Garage",
    "slug": "velopx-garage",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "velopx-garage",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#070C14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.velopx.garage",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "VelopX Garage uses your location to set the delivery destination for parts orders.",
        "NSLocationAlwaysUsageDescription": "VelopX Garage uses your location to set the delivery destination for parts orders."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#070C14"
      },
      "package": "com.velopx.garage",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-location", { "locationAlwaysAndWhenInUsePermission": "Allow VelopX Garage to use your location for delivery setup." }]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
